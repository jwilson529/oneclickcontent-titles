# Find a free TCP port from a preferred list.
find_free_port() {
    local ports=("$@")
    local port
    for port in "${ports[@]}"; do
        if command -v lsof >/dev/null 2>&1; then
            if ! lsof -n -P -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
                echo "$port"
                return 0
            fi
        elif command -v nc >/dev/null 2>&1; then
            if ! nc -z 127.0.0.1 "$port" >/dev/null 2>&1; then
                echo "$port"
                return 0
            fi
        else
            echo "$port"
            return 0
        fi
    done
    return 1
}

ensure_cstn_generator_repo() {
    if [ "$CSTN_GENERATOR_AUTO_INSTALL" != "true" ]; then
        return 1
    fi

    if ! command -v git >/dev/null 2>&1 || ! command -v node >/dev/null 2>&1; then
        return 1
