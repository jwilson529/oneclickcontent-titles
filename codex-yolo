# 5. Create a plugin error log file for Codex and the plugin
if [ ! -f "$LOG_FILE" ]; then
    echo "🧾 Creating plugin error log file at $LOG_FILE"
    [ "$DRY_RUN" = false ] && touch "$LOG_FILE"
else
    echo "🧾 Plugin error log file exists: $LOG_FILE"
fi

# 6. Build Codex instruction message
if [ -n "${CODEX_MSG:-}" ]; then
    # If you pass args to this script, they override the default instruction.
    : # CODEX_MSG already set from arguments
else
    # Default: fully autonomous "make the plugin match the spec" instruction.
    CODEX_MSG=$'Read AGENTS.md and SPEC.md.\n\n\
In this run, your job is to autonomously implement or update the WordPress plugin in this repository so that it fully matches SPEC.md and follows all architecture and coding rules from AGENTS.md.\n\n\
Your goal in YOLO mode is to get this repository into a state where it is WPCS compliant, has a complete WPPB style structure, has phpunit wired, has logging wired, and is ready for active feature development.\n\n\
When you notice missing or incomplete elements (for example ABSPATH guards, PHPUnit config, tests/, phpcs.xml, package.json scripts, or a Logger), you must create and wire them yourself. Do NOT ask the user to do these things and do NOT list them as suggested next steps.\n\n\
Use check.txt produced by npm run check as your guide for coding standard cleanup and keep iterating toward a clean result.\n\n\
Very important: Do NOT ask what to update and do NOT output a list of things the user \"may want\" to do. Instead, apply the next concrete coding steps directly to the codebase.'
fi

echo
echo "🧾 Codex instruction:"
echo "$CODEX_MSG"
echo

if [ "$DRY_RUN" = true ]; then
    echo "🔍 DRY RUN: Would run Codex YOLO with above instruction"
    echo "   Skipping actual Codex execution..."
else
    echo "🤖 Running Codex YOLO..."
    echo

    RAN_CODEX_LOOP=true
    PASS=1
    CODEX_EXIT=0

    while [ "$PASS" -le "$MAX_ITERATIONS" ]; do
        log "🔁 Codex pass $PASS of $MAX_ITERATIONS"

        EXTRA_CONTEXT="$(build_codex_context || true)"

        CODEX_PASS_MSG="$CODEX_MSG"$'\n\n---\nAdditional context from last pass:\n'"$EXTRA_CONTEXT"$'\n---\n'

        set +e
        run_codex_unattended "$PLUGIN_DIR" "$CODEX_PASS_MSG"
        CODEX_EXIT=$?
        set -e

        if [ "$CODEX_EXIT" -ne 0 ]; then
            log "⚠️ Codex exit code $CODEX_EXIT on pass $PASS (continuing)"
        fi

        # Run fix/check after each pass.
        LAST_CHECK_OK=true
        if [ -f "$PLUGIN_DIR/package.json" ]; then
            npm run fix || true
            CHECK_EXIT=0
            npm run check || CHECK_EXIT=$?
            if [ "$CHECK_EXIT" -ne 0 ]; then
                LAST_CHECK_OK=false
                log "⚠️ npm run check failed on pass $PASS (exit $CHECK_EXIT). Skipping clean short-circuit."
            fi
        fi

        DOCKER_TEST_OK=true
        if [ "$DRY_RUN" = false ] && [ "$RUN_DOCKER_TESTS_EACH_PASS" = "true" ] && [ "$RUN_DOCKER_TESTS" = "true" ]; then
            if has_docker; then
                set +e
                docker_tests
                DOCKER_TEST_EXIT=$?
                set -e

                if [ "$DOCKER_TEST_EXIT" -ne 0 ]; then
                    DOCKER_TEST_OK=false
                    log "⚠️ Docker tests failed on pass $PASS (exit $DOCKER_TEST_EXIT). Continuing."
                else
                    log "✅ Docker tests passed on pass $PASS."
                fi
            else
                DOCKER_TEST_OK=false
                log "⚠️ Docker not available. Cannot verify PHPUnit on pass $PASS."
            fi
        fi

        # Stop early if clean.
        if [ "$LAST_CHECK_OK" = true ] && check_is_clean && [ "$DOCKER_TEST_OK" = true ]; then
            log "✅ Clean state achieved (PHPCS + PHPUnit). Stopping early."
            CLEAN_BASELINE=true
            break
        fi

        PASS=$((PASS + 1))
    done

    echo
    echo "✅ Codex loop finished after $PASS pass(es)."
    display_check_summary
    echo

    if [ "$CODEX_EXIT" -eq 0 ]; then
        echo "✅ Last Codex exit code: 0"
    else
        echo "⚠️  Last Codex exit code: $CODEX_EXIT"
    fi
fi

# 7. Run npm fix and check (optional final pass)
if [ "$RUN_FINAL_CHECK" = "true" ] && command -v npm >/dev/null 2>&1 && [ -f "$PLUGIN_DIR/package.json" ] && [ "$DRY_RUN" = false ]; then
    echo
    echo "🧹 Running npm run fix"
    if ! npm run fix; then
        echo "⚠️  npm run fix reported issues."
    fi

    echo
    echo "🔎 Running npm run check (output to check.txt)"
    CHECK_EXIT=0
    if ! npm run check; then
        CHECK_EXIT=$?
        echo "⚠️  npm run check reported coding standard issues. See check.txt."
    else
        echo "✅ npm run check completed. See check.txt for details."
    fi
    
    # Display summary
    display_check_summary
    if [ "$CHECK_EXIT" -eq 0 ] && check_is_clean; then
        CLEAN_BASELINE=true
    fi
else
    if [ "$DRY_RUN" = true ]; then
        echo
        echo "🔍 DRY RUN: Would run npm fix and check"
    elif [ "$RUN_FINAL_CHECK" != "true" ] && [ "$RAN_CODEX_LOOP" = true ]; then
        echo
        echo "ℹ️  Final npm fix/check skipped (already ran per-pass)."
    else
        echo
        echo "⚠️  npm or package.json not available, skipping fix/check."
    fi
fi

# 7.5 Run docker tests after Codex loop and npm checks
if [ "$DRY_RUN" = false ] && [ "$RUN_DOCKER_TESTS" = "true" ]; then
    if has_docker; then
        set +e
        docker_tests
        DOCKER_TEST_EXIT=$?
        set -e

        if [ "$DOCKER_TEST_EXIT" -ne 0 ]; then
            log "⚠️ Docker tests failed after Codex (exit $DOCKER_TEST_EXIT). Continuing."
        else
            log "✅ Docker tests passed after Codex."
        fi
    else
        log "ℹ️ Docker not available. Skipping docker tests."
    fi
fi

# 8. Stage all changes in git, if this is a git repo
if [ -d "$PLUGIN_DIR/.git" ] && [ "$DRY_RUN" = false ]; then
    echo
    echo "📚 Staging changes (post Codex)..."
    git add -A
    
    # Create descriptive commit if there are changes
    if ! git diff-index --quiet HEAD -- 2>/dev/null; then
        error_count=$(grep -c "ERROR" "$PLUGIN_DIR/check.txt" 2>/dev/null || echo "0")
        warn_count=$(grep -c "WARNING" "$PLUGIN_DIR/check.txt" 2>/dev/null || echo "0")
        
        git commit -m "chore: codex auto-update [$(date +'%Y-%m-%d %H:%M')]

- Applied WPCS fixes
- Updated structure per AGENTS.md
- Errors: $error_count | Warnings: $warn_count" 2>/dev/null || true
        
        echo "✅ Changes committed"
    else
        echo "📚 No changes to commit"
    fi
    
    git status -sb
else
    if [ "$DRY_RUN" = true ]; then
        echo
        echo "🔍 DRY RUN: Would stage and commit changes"
    else
        echo
        echo "ℹ️  No git repository detected. Skipping git add."
    fi
fi

if [ "$DRY_RUN" = false ] && [ "$KEEP_CODEX_OPEN" = "true" ]; then
    echo
    echo "🟢 Opening Codex for next steps..."
    run_codex_interactive "$PLUGIN_DIR"
fi

echo
echo "✨ Done. WPPB (if used) flattened, git initialized, Codex run, check.txt and plugin-error.log ready for the next round."
