fi

# 3.2 Ensure phpunit.xml.dist exists
if [ -f "$PLUGIN_DIR/phpunit.xml.dist" ]; then
    echo "🧪 phpunit.xml.dist found"
else
    echo "🧪 No phpunit.xml.dist found, creating a default."
    [ "$DRY_RUN" = false ] && cat > "$PLUGIN_DIR/phpunit.xml.dist" <<'EOF'
