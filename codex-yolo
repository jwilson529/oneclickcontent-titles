# ============================================================================
# Run codex.
# ============================================================================
run_codex_unattended() {
    local codex_dir="$1"
    local codex_msg="$2"

    if [ "$USE_EXPECT" = "true" ] && command -v expect >/dev/null 2>&1; then
        CODEX_DIR="$codex_dir" CODEX_MSG="$codex_msg" expect <<'EOF'
            set timeout -1
            log_user 1
            set codex_dir $env(CODEX_DIR)
            set codex_msg $env(CODEX_MSG)
            set cmd [list codex --cd $codex_dir --yolo $codex_msg]
            spawn {*}$cmd
            expect {
                -re {(?i)save.*continue} { send "y\r"; exp_continue }
                -re {(?i)continue\?} { send "y\r"; exp_continue }
                -re {(?i)proceed\?} { send "y\r"; exp_continue }
                -re {(?i)\(y/n\)} { send "y\r"; exp_continue }
                -re {(?i)press.*enter} { send "\r"; exp_continue }
                eof
            }
            if { [catch wait result] } {
                exit 0
            }
            if { [llength $result] < 4 } {
                exit 0
            }
            exit [lindex $result 3]
EOF
        return $?
    fi

    codex --cd "$codex_dir" --yolo "$codex_msg"
}

run_codex_interactive() {
    local codex_dir="$1"
    codex --cd "$codex_dir"
}

build_codex_context() {
    local context=""

    if [ -f "$PLUGIN_DIR/check.txt" ]; then
        local errors warnings
        errors=$(grep -c "ERROR" "$PLUGIN_DIR/check.txt" 2>/dev/null || echo "0")
        warnings=$(grep -c "WARNING" "$PLUGIN_DIR/check.txt" 2>/dev/null || echo "0")

        context+=$'\n\nPHPCS summary:\n'
        context+="Errors: ${errors}, Warnings: ${warnings}"$'\n'

        if [ "$errors" -gt 0 ] || [ "$warnings" -gt 0 ]; then
            context+=$'\nTop PHPCS lines:\n'
            context+="$(head -50 "$PLUGIN_DIR/check.txt")"
            context+=$'\n'
        fi
    fi

    if [ -d "$PLUGIN_DIR/.git" ]; then
        context+=$'\n\nGit diff stat:\n'
        context+="$(git diff --stat HEAD 2>/dev/null || true)"
        context+=$'\n'
    fi

    if [ -n "$CODEX_YOLO_PLAYBOOK_PATH" ] && [ -f "$CODEX_YOLO_PLAYBOOK_PATH" ]; then
        context+=$'\n\nPlaybook (last 30 lines):\n'
        context+="$(tail -n 30 "$CODEX_YOLO_PLAYBOOK_PATH" 2>/dev/null || true)"
        context+=$'\n'
    fi

    echo "$context"
}

# Write a file only if missing. If present, keep it.
# If it was generated by this script before, allow upgrades.
ensure_managed_file() {
    local path="$1"
    local label="$2"
    local marker="$3"
    local content="$4"

    if [ -f "$path" ]; then
        # If it's our managed file, we can optionally upgrade it.
        if grep -qF "$marker" "$path" 2>/dev/null; then
            local tmp
            tmp="$(mktemp)"
            printf '%s\n' "$content" > "$tmp"
            if cmp -s "$tmp" "$path"; then
                echo "🧠 $label exists (managed). Leaving as-is."
                rm -f "$tmp"
            else
                echo "🧠 $label exists (managed). Updating."
                if [ "$DRY_RUN" = false ]; then
                    mv "$tmp" "$path"
                else
                    rm -f "$tmp"
                fi
            fi
        else
            echo "🧠 $label exists (user). Leaving as-is."
        fi
        return 0
    fi

    echo "🧠 Creating $label"
    if [ "$DRY_RUN" = false ]; then
        # Atomic write.
        local tmp
        tmp="$(mktemp)"
        printf '%s\n' "$content" > "$tmp"
        mv "$tmp" "$path"
    fi
}

