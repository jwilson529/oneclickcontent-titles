    echo "📦 Git repository already exists, skipping init."
fi


# 3. Ensure package.json exists with required scripts
if [ -f "$PLUGIN_DIR/package.json" ]; then
    echo "📦 package.json found, verifying scripts..."
    if command -v python3 >/dev/null 2>&1; then
        python3 - <<PY
import json, os, sys
pkg_path = os.path.join("${PLUGIN_DIR}", "package.json")
with open(pkg_path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
scripts = data.get("scripts", {})
scripts["test"] = "docker compose up --abort-on-container-exit --exit-code-from tests tests"
scripts["test:local"] = "phpunit"
scripts["fix"] = "phpcbf -d memory_limit=512M -d error_reporting=\\"E_ALL&~E_DEPRECATED\\" --standard=phpcs.xml.dist --extensions=php ."
scripts["check"] = "phpcs -d memory_limit=512M -d error_reporting=\\"E_ALL&~E_DEPRECATED\\" --standard=phpcs.xml.dist --extensions=php . > check.txt"
data["scripts"] = scripts
with open(pkg_path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2)
    fh.write("\\n")
PY
    else
        if ! grep -q '"fix"' "$PLUGIN_DIR/package.json" || ! grep -q '"check"' "$PLUGIN_DIR/package.json"; then
            echo "⚠️  package.json missing required 'fix' or 'check' scripts."
            echo "    Please ensure these scripts are defined per AGENTS.md."
        fi
    fi
else
    echo "📦 No package.json found, creating one with standard scripts."
    [ "$DRY_RUN" = false ] && cat > "$PLUGIN_DIR/package.json" <<EOF
{
  "name": "$PLUGIN_SLUG",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "docker compose up --abort-on-container-exit --exit-code-from tests tests",
    "test:local": "phpunit",
    "fix": "phpcbf -d memory_limit=512M -d error_reporting=\\"E_ALL&~E_DEPRECATED\\" --standard=phpcs.xml.dist --extensions=php .",
    "check": "phpcs -d memory_limit=512M -d error_reporting=\\"E_ALL&~E_DEPRECATED\\" --standard=phpcs.xml.dist --extensions=php . > check.txt",
    "phpmd": "phpmd . text phpmd.xml --exclude vendor,node_modules,.codex-backups > phpmd.txt",
    "dist": "rm -f $PLUGIN_SLUG.zip && zip -r $PLUGIN_SLUG.zip . -x \\"*/.*\\" \\"*.log\\" \\"*.zip\\" \\"node_modules/*\\" \\"vendor/*\\" \\".git/*\\" \\".github/*\\" \\".wp-core/*\\" \\".wp-tests/*\\" \\".codex-backups/*\\" \\"check.txt\\" \\"phpmd.txt\\" \\"package.json\\" \\"package-lock.json\\" \\"composer.json\\" \\"phpmd.xml\\" \\".codex_index.json\\" \\".codex_run_meta.json\\" \\".codex_tasks.csv\\" \\"README.md\\"",
    "plugin-check": "wp plugin check .",
    "update-wpcs": "composer global require wp-coding-standards/wpcs --update-with-all-dependencies",
    "update-phpcs": "composer global require squizlabs/php_codesniffer --update-with-all-dependencies",
    "refresh-phpcs": "phpcs --clear-cache && phpcs --config-set installed_paths ~/.composer/vendor/wp-coding-standards/wpcs"
  }
}
EOF
fi

# 3.1 Ensure phpcs.xml.dist exists
if [ -f "$PLUGIN_DIR/phpcs.xml.dist" ]; then
    echo "🧹 phpcs.xml.dist found"
else
    echo "🧹 No phpcs.xml.dist found, creating a default."
    [ "$DRY_RUN" = false ] && cat > "$PLUGIN_DIR/phpcs.xml.dist" <<'EOF'
