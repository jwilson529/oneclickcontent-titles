install_dependencies() {
    local tools=("$@")
    local os_name
    os_name="$(uname -s 2>/dev/null || echo unknown)"

    if command -v brew >/dev/null 2>&1; then
        for tool in "${tools[@]}"; do
            case "$tool" in
                npm) brew install node ;;
                git) brew install git ;;
                php) brew install php ;;
                codex)
                    if command -v npm >/dev/null 2>&1; then
                        npm install -g @openai/codex
                    fi
                    ;;
            esac
        done
        return 0
    fi

    if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update -y
        for tool in "${tools[@]}"; do
            case "$tool" in
                npm) sudo apt-get install -y nodejs npm ;;
                git) sudo apt-get install -y git ;;
                php) sudo apt-get install -y php-cli ;;
                codex)
                    if command -v npm >/dev/null 2>&1; then
                        sudo npm install -g @openai/codex
                    fi
                    ;;
            esac
        done
        return 0
    fi

    if command -v dnf >/dev/null 2>&1; then
        for tool in "${tools[@]}"; do
            case "$tool" in
                npm) sudo dnf install -y nodejs ;;
                git) sudo dnf install -y git ;;
                php) sudo dnf install -y php-cli ;;
                codex)
                    if command -v npm >/dev/null 2>&1; then
                        sudo npm install -g @openai/codex
                    fi
                    ;;
            esac
        done
        return 0
    fi

    if command -v yum >/dev/null 2>&1; then
        for tool in "${tools[@]}"; do
            case "$tool" in
                npm) sudo yum install -y nodejs ;;
                git) sudo yum install -y git ;;
                php) sudo yum install -y php-cli ;;
                codex)
                    if command -v npm >/dev/null 2>&1; then
                        sudo npm install -g @openai/codex
                    fi
                    ;;
            esac
        done
        return 0
    fi

    if command -v pacman >/dev/null 2>&1; then
        sudo pacman -Sy --noconfirm
        for tool in "${tools[@]}"; do
            case "$tool" in
                npm) sudo pacman -S --noconfirm nodejs npm ;;
                git) sudo pacman -S --noconfirm git ;;
                php) sudo pacman -S --noconfirm php ;;
                codex)
                    if command -v npm >/dev/null 2>&1; then
                        sudo npm install -g @openai/codex
                    fi
                    ;;
            esac
        done
        return 0
    fi

    echo "⚠️  No supported package manager found on $os_name."
    echo "   Install missing dependencies manually, then re-run."
    return 1
