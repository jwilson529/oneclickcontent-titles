    local install_dir="$PLUGIN_DIR/.cstn-generator"

    if [ ! -d "$install_dir/.git" ]; then
        rm -rf "$install_dir"
        git clone --depth=1 --branch "$CSTN_GENERATOR_REF" "$CSTN_GENERATOR_REPO" "$install_dir" >/dev/null 2>&1 || return 1
