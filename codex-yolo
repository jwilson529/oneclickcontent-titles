# Senior Developer: Makes autonomous decisions on common questions
senior_decide() {
    local question_type="$1"
    local context="${2:-}"
    
    log "🧠 Senior Developer consulting on: $question_type"
    
    case "$question_type" in
        "plugin_name")
            # Generate plugin name from directory
            local plugin_name=$(echo "$PLUGIN_SLUG" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++)sub(/./,toupper(substr($i,1,1)),$i)}1')
            echo "$plugin_name"
            log "✓ Senior decided plugin name: $plugin_name"
            ;;
            
        "plugin_description")
            echo "A modern WordPress plugin built with WPPB architecture and WPCS compliance."
            log "✓ Senior decided on standard description"
            ;;
            
        "author_name")
            # Try to get from git config
            local author=$(git config user.name 2>/dev/null || echo "WordPress Developer")
            echo "$author"
            log "✓ Senior decided author: $author"
            ;;
            
        "author_email")
            # Try to get from git config
            local email=$(git config user.email 2>/dev/null || echo "dev@example.com")
            echo "$email"
            log "✓ Senior decided email: $email"
            ;;
            
        "author_url")
            # Try to get from git remote or use placeholder
            local url=$(git config user.url 2>/dev/null || echo "https://example.com")
            echo "$url"
            log "✓ Senior decided URL: $url"
            ;;
            
        "text_domain")
            echo "$PLUGIN_SLUG"
            log "✓ Senior decided text domain: $PLUGIN_SLUG"
            ;;
            
        "namespace")
            # Convert plugin-slug to Plugin_Namespace
            local namespace=$(echo "$PLUGIN_SLUG" | sed 's/-/_/g' | awk '{for(i=1;i<=NF;i++)sub(/./,toupper(substr($i,1,1)),$i)}1' | sed 's/ /_/g')
            echo "$namespace"
            log "✓ Senior decided namespace: $namespace"
            ;;
            
        "create_scaffold")
            # Senior always says yes to creating missing structure
            echo "yes"
            log "✓ Senior approved scaffold creation"
            ;;
            
        "install_dependencies")
            # Senior approves installing standard dev dependencies
            echo "yes"
            log "✓ Senior approved dependency installation"
            ;;
            
        "fix_violations")
            # Senior always approves fixing WPCS violations
            echo "yes"
            log "✓ Senior approved fixing violations"
            ;;
            
        *)
            # Unknown question - need actual user input
            log "⚠️ Senior cannot decide on: $question_type - needs user input"
            return 1
            ;;
    esac
    
    return 0
}

# Ask Senior Developer or fall back to user
ask_decision() {
    local question_type="$1"
    local prompt_message="$2"
    local default_value="${3:-}"
    
    if [ "$AUTO_DECIDE" = true ]; then
        # Try Senior Developer first
        if senior_decide "$question_type" 2>/dev/null; then
            return 0
        fi
    fi
    
    # Senior couldn't decide or AUTO_DECIDE is off - ask user
    notify_user "USER INPUT NEEDED: $prompt_message"
    
    if [ -n "$default_value" ]; then
        read -p "$prompt_message [$default_value]: " response
        echo "${response:-$default_value}"
    else
        read -p "$prompt_message: " response
        echo "$response"
    fi
}

# Generate WPPB scaffold autonomously without interactive prompts
