    echo "   Plugin Name: $plugin_name"
    echo "   Plugin Slug: $plugin_slug"
    echo "   Description: $description"
    echo "   Author: $author <$email>"
    echo "   Author URL: $url"
    echo "   Namespace: $namespace"
    echo ""
    
    # Create basic WPPB structure manually
    mkdir -p "$PLUGIN_DIR/includes"
    mkdir -p "$PLUGIN_DIR/admin"
    mkdir -p "$PLUGIN_DIR/admin/css"
    mkdir -p "$PLUGIN_DIR/admin/js"
    mkdir -p "$PLUGIN_DIR/public"
    mkdir -p "$PLUGIN_DIR/public/css"
    mkdir -p "$PLUGIN_DIR/public/js"
    mkdir -p "$PLUGIN_DIR/tests"
    
    # Create main plugin file
    cat > "$PLUGIN_DIR/$plugin_slug.php" <<EOF
<?php
/**
 * Plugin Name:       $plugin_name
 * Plugin URI:        $url
 * Description:       $description
 * Version:           0.1.0
 * Author:            $author
 * Author URI:        $url
 * License:           GPL-2.0+
 * License URI:       http://www.gnu.org/licenses/gpl-2.0.txt
 * Text Domain:       $plugin_slug
 * Domain Path:       /languages
 */

defined( 'ABSPATH' ) || exit;

// Plugin version.
define( '${namespace}_VERSION', '0.1.0' );

// Plugin directory path.
define( '${namespace}_PATH', plugin_dir_path( __FILE__ ) );

// Plugin directory URL.
define( '${namespace}_URL', plugin_dir_url( __FILE__ ) );

/**
 * Plugin activation hook.
 */
function ${plugin_slug//-/_}_activate() {
    require_once ${namespace}_PATH . 'includes/class-activator.php';
    ${namespace}_Activator::activate();
}
register_activation_hook( __FILE__, '${plugin_slug//-/_}_activate' );

/**
 * Plugin deactivation hook.
 */
function ${plugin_slug//-/_}_deactivate() {
    require_once ${namespace}_PATH . 'includes/class-deactivator.php';
    ${namespace}_Deactivator::deactivate();
}
register_deactivation_hook( __FILE__, '${plugin_slug//-/_}_deactivate' );

/**
 * Load plugin core class.
 */
require ${namespace}_PATH . 'includes/class-${plugin_slug}.php';

/**
 * Initialize plugin.
 */
function ${plugin_slug//-/_}_run() {
    \$plugin = new ${namespace}();
    \$plugin->run();
}
${plugin_slug//-/_}_run();
EOF

    # Create basic loader class
    cat > "$PLUGIN_DIR/includes/class-loader.php" <<EOF
<?php
/**
 * Loader class.
 *
 * @package    $namespace
 */

defined( 'ABSPATH' ) || exit;

/**
 * Register all actions and filters for the plugin.
 */
class ${namespace}_Loader {

    /**
     * Array of actions registered with WordPress.
     *
     * @var array
     */
    protected \$actions = array();

    /**
     * Array of filters registered with WordPress.
     *
     * @var array
     */
    protected \$filters = array();

    /**
     * Add a new action to be registered.
     *
     * @param string \$hook          Hook name.
     * @param object \$component     Component instance.
     * @param string \$callback      Callback method.
     * @param int    \$priority      Hook priority.
     * @param int    \$accepted_args Number of accepted arguments.
     */
    public function add_action( \$hook, \$component, \$callback, \$priority = 10, \$accepted_args = 1 ) {
        \$this->actions = \$this->add( \$this->actions, \$hook, \$component, \$callback, \$priority, \$accepted_args );
    }

    /**
     * Add a new filter to be registered.
     *
     * @param string \$hook          Hook name.
     * @param object \$component     Component instance.
     * @param string \$callback      Callback method.
     * @param int    \$priority      Hook priority.
     * @param int    \$accepted_args Number of accepted arguments.
     */
    public function add_filter( \$hook, \$component, \$callback, \$priority = 10, \$accepted_args = 1 ) {
        \$this->filters = \$this->add( \$this->filters, \$hook, \$component, \$callback, \$priority, \$accepted_args );
    }

    /**
     * Add hook to collection.
     *
     * @param array  \$hooks         Hook collection.
     * @param string \$hook          Hook name.
     * @param object \$component     Component instance.
     * @param string \$callback      Callback method.
     * @param int    \$priority      Hook priority.
     * @param int    \$accepted_args Number of accepted arguments.
     * @return array
     */
    private function add( \$hooks, \$hook, \$component, \$callback, \$priority, \$accepted_args ) {
        \$hooks[] = array(
            'hook'          => \$hook,
            'component'     => \$component,
            'callback'      => \$callback,
            'priority'      => \$priority,
            'accepted_args' => \$accepted_args,
        );
        return \$hooks;
    }

    /**
     * Register all hooks with WordPress.
     */
    public function run() {
        foreach ( \$this->filters as \$hook ) {
            add_filter(
                \$hook['hook'],
                array( \$hook['component'], \$hook['callback'] ),
                \$hook['priority'],
                \$hook['accepted_args']
            );
        }

        foreach ( \$this->actions as \$hook ) {
            add_action(
                \$hook['hook'],
                array( \$hook['component'], \$hook['callback'] ),
                \$hook['priority'],
                \$hook['accepted_args']
            );
        }
    }
}
EOF

    log "✅ Senior Developer: WPPB scaffold generated autonomously"
}

# Structured logging with timestamps
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

append_run_recap() {
    local exit_code="$1"
    local docker_status="${2:-unknown}"
    local check_status="${3:-unknown}"
    local note="${4:-}"

    if [ ! -f "$MEMORY_FILE" ]; then
        if [ "$LEARN_DEBUG" = "true" ]; then
            echo "⚠️  MEMORY.md missing, creating minimal file for run recap." >&2
        fi
        printf '%s\n' "# Project Memory" "" "## Run recap log" > "$MEMORY_FILE"
    fi

    {
        echo ""
        echo "## Run recap ($(date +'%Y-%m-%d %H:%M:%S'))"
        echo "- Exit code: ${exit_code}"
        echo "- Docker: ${docker_status}"
        echo "- PHPCS: ${check_status}"
        [ -n "${MYSQL_PORT:-}" ] && echo "- MySQL port: ${MYSQL_PORT}"
        [ -n "$note" ] && echo "- Note: ${note}"
    } >> "$MEMORY_FILE"

    if [ -n "$CODEX_YOLO_PLAYBOOK_PATH" ]; then
        mkdir -p "$(dirname "$CODEX_YOLO_PLAYBOOK_PATH")" 2>/dev/null || true
        {
            echo "[$(date +'%Y-%m-%d %H:%M:%S')] ${PLUGIN_SLUG} | exit=${exit_code} | docker=${docker_status} | phpcs=${check_status} | port=${MYSQL_PORT:-n/a} | ${note}"
        } >> "$CODEX_YOLO_PLAYBOOK_PATH"
    fi

    if [ "$LEARN_DEBUG" = "true" ]; then
        echo "✅ Learning recap appended." >&2
    fi
}

# Docker helpers
has_docker() {
    command -v docker >/dev/null 2>&1 || return 1
    docker info >/dev/null 2>&1 || return 1
    docker_compose_cmd >/dev/null 2>&1 || return 1
    return 0
}

docker_compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        echo "docker compose"
        return 0
    fi
    if command -v docker-compose >/dev/null 2>&1; then
        echo "docker-compose"
        return 0
    fi
    return 1
}

docker_up() {
    local dc
    dc="$(docker_compose_cmd)"
    log "🐳 Docker: bringing up db"
    $dc up -d db >/dev/null
}

docker_tests() {
    local dc
    dc="$(docker_compose_cmd)"
    log "🧪 Docker: running PHPUnit in container"
    $dc run --rm tests
}

docker_down() {
    local dc
    dc="$(docker_compose_cmd)"
    log "🧹 Docker: tearing down stack"
