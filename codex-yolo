fi

# 3.3 Ensure PHPUnit bootstrap exists
if [ -f "$PLUGIN_DIR/tests/bootstrap.php" ]; then
    echo "🧪 tests/bootstrap.php found"
else
    echo "🧪 No tests/bootstrap.php found, creating a default."
    [ "$DRY_RUN" = false ] && mkdir -p "$PLUGIN_DIR/tests"
    [ "$DRY_RUN" = false ] && cat > "$PLUGIN_DIR/tests/bootstrap.php" <<'EOF'
<?php
/**
 * PHPUnit bootstrap file.
 *
 * @package Plugin
 */

if ( ! defined( 'ABSPATH' ) && ! getenv( 'WP_TESTS_DIR' ) && ! is_dir( dirname( __DIR__ ) . '/.wp-tests' ) ) {
    exit;
}

$_tests_dir = getenv( 'WP_TESTS_DIR' );

if ( ! $_tests_dir ) {
    $_tests_dir = dirname( __DIR__ ) . '/.wp-tests';
}

if ( ! defined( 'WP_TESTS_DIR' ) ) {
    define( 'WP_TESTS_DIR', $_tests_dir );
}

require_once WP_TESTS_DIR . '/includes/functions.php';

/**
 * Load the plugin for integration tests.
 */
function plugin_load_for_tests() {
    $plugin_file = glob( dirname( __DIR__ ) . '/*.php' );
    if ( ! empty( $plugin_file[0] ) ) {
        require $plugin_file[0];
    }
}

tests_add_filter( 'muplugins_loaded', 'plugin_load_for_tests' );

require_once WP_TESTS_DIR . '/includes/bootstrap.php';
EOF
fi

