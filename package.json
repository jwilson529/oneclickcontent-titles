{
  "name": "oneclickcontent-titles",
  "version": "2.1.1",
  "description": "Free AI title assistant for WordPress from the OneClickContent bring-your-own-key AI plugin line.",
  "main": "index.js",
  "scripts": {
    "test": "docker compose up --abort-on-container-exit --exit-code-from tests tests",
    "fix": "vendor/bin/phpcbf -d memory_limit=512M -d error_reporting=\"E_ALL&~E_DEPRECATED\" --standard=phpcs.xml.dist --extensions=php .",
    "check": "vendor/bin/phpcs -d memory_limit=512M -d error_reporting=\"E_ALL&~E_DEPRECATED\" --standard=phpcs.xml.dist --extensions=php . > check.txt",
    "phpmd": "vendor/bin/phpmd . text phpmd.xml --exclude vendor,node_modules > phpmd.txt",
    "dist": "bash bin/build-dist.sh",
    "plugin-check": "wp plugin check .",
    "update-wpcs": "composer global require wp-coding-standards/wpcs --update-with-all-dependencies",
    "update-phpcs": "composer global require squizlabs/php_codesniffer --update-with-all-dependencies",
    "refresh-phpcs": "phpcs --clear-cache && phpcs --config-set installed_paths ~/.composer/vendor/wp-coding-standards/wpcs",
    "test:local": "vendor/bin/phpunit -c phpunit.xml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwilson529/oneclickcontent-titles.git"
  },
  "author": "",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/jwilson529/oneclickcontent-titles/issues"
  },
  "homepage": "https://github.com/jwilson529/oneclickcontent-titles#readme"
}
